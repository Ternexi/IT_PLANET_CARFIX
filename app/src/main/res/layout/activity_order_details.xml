<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/order_id_details"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Номер заказа:"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/orderCarNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:text="Номер авто:"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/orderTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:text="Дата:"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/zapchasti"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:text="Запчасти:"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Блок для скрытого дефекта -->
        <TextView
            android:id="@+id/hidden_defect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Дополнительные работы (скрытый дефект):"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/hidden_defect_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="16sp"
            android:visibility="gone"
            tools:text=" • Царапина на крыле"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/hidden_defect_cost_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="16sp"
            android:visibility="gone"
            tools:text="Стоимость доп. работ: 5000 р."
            tools:visibility="visible" />
        <!-- Конец блока -->

        <TextView
            android:id="@+id/orderCost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:text="Итого к оплате:"
            android:textColor="@android:color/black"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
