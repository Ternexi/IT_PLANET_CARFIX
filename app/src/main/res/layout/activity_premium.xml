<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    tools:context=".PremiumActivity">

    <!-- Кнопка "Подключить", прижатая к низу экрана -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/connect_button"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        android:text="Подключить"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="#566C64"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ScrollView для всего остального контента, чтобы он прокручивался -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="16dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/connect_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Блок Заголовка с логотипом -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/logo_icon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@mipmap/black_new" /> <!-- ЗАМЕНИ НА СВОЮ ИКОНКУ -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="CarFix Premium"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Подзаголовок "Привилегии с CarFix" -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:text="Привилегии с CarFix"
                android:textColor="@android:color/white"
                android:textSize="18sp" />

            <!-- Горизонтальный контейнер для двух верхних карточек -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <!-- Карточка 1: Неограниченное расширение -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/shape_premium_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/icon_clients"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/profile_svg" /> <!-- ЗАМЕНИ НА СВОЮ ИКОНКУ -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="4dp"
                        android:text="Неограниченное расширение клиентской базы"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="4dp"
                        android:text="Снимайте все лимиты на добавление новых клиентов и масштабируйте ваш сервис без препятствий."
                        android:textColor="#B0B0B0"
                        android:textSize="12sp" />
                </LinearLayout>

                <Space
                    android:layout_width="16dp"
                    android:layout_height="match_parent" />

                <!-- Карточка 2: Мгновенный доступ -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/shape_premium_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/icon_repair"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/beskonechnost" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="4dp"
                        android:text="Мгновенный доступ к данным ремонта"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="4dp"
                        android:text="Получайте полную и неограниченную отчётность по каждой операции и истории обслуживания любого клиента, гарантируя прозрачность и качество."
                        android:textColor="#B0B0B0"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Карточка 3: Полная автоматизация -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/shape_premium_card"
                android:orientation="vertical"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/icon_automation"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/auto" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="Полная автоматизация бизнес-процессов и расширенный поиск"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="Получите эксклюзивный доступ к расширенному калькулятору и детализированной аналитике по всем клиентам и периодам... Достаточно ввести только государственный номер автомобиля для мгновенного получения полных данных."
                    android:textColor="#B0B0B0"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Карточка 4: Тарифы -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/shape_premium_card"
                android:orientation="vertical"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/icon_tariffs"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/card" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Основные тарифы подписки"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="1 месяц: 1090р"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="6 месяцев: 5800р (Выгоднее на 10%!)"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
    