        android:gravity="center"
        android:text="Номер не выбран"
        android:textColor="#566C64"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="@+id/premiumButton"
        app:layout_constraintEnd_toStartOf="@+id/settings_buton"
        app:layout_constraintStart_toEndOf="@+id/premiumButton"
        app:layout_constraintTop_toTopOf="@+id/premiumButton" />

