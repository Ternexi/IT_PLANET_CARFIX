        app:layout_constraintEnd_toStartOf="@+id/hidden_defects_input_right"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/hidden_defects_input_right"
        android:textColor="@color/black"
        android:layout_width="0dp"
        android:textColorHint="#B0B0B0"
        android:layout_height="50dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/shape_rounded_input_light"
        android:gravity="center"
        android:hint="Стоимость"
        android:inputType="number"
        android:paddingHorizontal="16dp"
        android:textSize="14sp"
        app:layout_constraintTop_toTopOf="@+id/hidden_defects_input_left"
        app:layout_constraintBottom_toBottomOf="@+id/hidden_defects_input_left"
        app:layout_constraintStart_toEndOf="@+id/hidden_defects_input_left"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/hidden_defects_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="скрытые дефекты"
        android:textColor="#585555"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@+id/hidden_defects_input_left"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>



